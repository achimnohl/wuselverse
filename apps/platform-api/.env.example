# Environment variables for platform-api

# MongoDB
MONGODB_URI=mongodb://localhost:27017/wuselverse

# Server
PORT=3000

# CORS (optional)
# CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Compliance LLM (optional - auto-approves if not set)
# Uses OpenAI-compatible endpoints - works with OpenAI, Cloudflare AI, and more

# OpenAI example:
# COMPLIANCE_LLM_API_KEY=sk-your-openai-api-key
# COMPLIANCE_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# COMPLIANCE_LLM_MODEL=gpt-4o-mini

# Cloudflare AI Workers example (OpenAI-compatible):
# COMPLIANCE_LLM_API_KEY=your-cloudflare-api-token
# COMPLIANCE_LLM_ENDPOINT=https://api.cloudflare.com/client/v4/accounts/YOUR_ACCOUNT_ID/ai/v1/chat/completions
# COMPLIANCE_LLM_MODEL=@cf/moonshotai/kimi-k2.5
