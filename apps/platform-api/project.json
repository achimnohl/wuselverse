{
  "name": "platform-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/platform-api/src",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/platform-api",
        "main": "apps/platform-api/src/main.ts",
        "tsConfig": "apps/platform-api/tsconfig.app.json",
        "assets": [],
        "webpackConfig": "apps/platform-api/webpack.config.js"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "platform-api:build",
        "runBuildTargetDependencies": true,
        "watch": true
      },
      "configurations": {
        "production": {
          "buildTarget": "platform-api:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/platform-api/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/platform-api/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["type:app", "platform:node"]
}
