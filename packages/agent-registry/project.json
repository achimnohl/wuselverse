{
  "name": "agent-registry",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/agent-registry/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/agent-registry/dist",
        "main": "packages/agent-registry/src/index.ts",
        "tsConfig": "packages/agent-registry/tsconfig.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/agent-registry/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/agent-registry/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": ["type:library", "scope:platform"]
}
