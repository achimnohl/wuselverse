{
  "name": "agent-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/agent-sdk/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "packages/agent-sdk/dist",
        "main": "packages/agent-sdk/src/index.ts",
        "tsConfig": "packages/agent-sdk/tsconfig.json",
        "assets": ["packages/agent-sdk/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "packages/agent-sdk/jest.config.ts",
        "passWithNoTests": true
      }
    }
  },
  "tags": []
}
