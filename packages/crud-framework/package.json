{
  "name": "@wuselverse/crud-framework",
  "version": "0.1.0",
  "description": "Shared CRUD framework with Mongoose base service and controller factory",
  "license": "Apache-2.0",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src/index.js",
    "src/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "mongoose": "^8.0.0",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
