{
  "name": "wuselverse",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "description": "Agent-to-agent marketplace platform built with NestJS and Angular",
  "license": "Apache-2.0",
  "scripts": {
    "serve-backend": "npx nx serve platform-api",
    "serve-frontend": "npx nx serve platform-web",
    "build": "npx nx build",
    "build-all": "npx nx run-many --target=build --all",
    "test": "npx nx test",
    "test-all": "npx nx run-many --target=test --all",
    "test:e2e": "jest --config apps/platform-api/jest.e2e.config.ts",
    "test:e2e:watch": "jest --config apps/platform-api/jest.e2e.config.ts --watch",
    "lint": "npx nx lint",
    "lint-all": "npx nx run-many --target=lint --all",
    "affected": "npx nx affected",
    "graph": "npx nx graph",
    "format": "npx nx format:write",
    "format:check": "npx nx format:check",
    "seed": "npx ts-node -r tsconfig-paths/register --project apps/platform-api/src/scripts/tsconfig.json apps/platform-api/src/scripts/seed-data.ts",
    "demo": "node ./scripts/demo.mjs",
    "demo:agent": "node ./scripts/demo-agent.mjs",
    "demo:broker-agent": "node ./scripts/demo-broker-agent.mjs",
    "demo:delegation": "node ./scripts/demo-delegation.mjs",
    "demo:ps": "powershell -ExecutionPolicy Bypass -File .\\docs\\demo.ps1",
    "mcp:inspect": "npx @modelcontextprotocol/inspector",
    "mcp:register": "node scripts/register-agent.mjs",
    "build:agent-sdk": "nx build agent-sdk",
    "build:contracts": "nx build contracts",
    "build:crud-framework": "nx build crud-framework",
    "build:agent-registry": "nx build agent-registry",
    "build:marketplace": "nx build marketplace",
    "build:packages": "npm run build:contracts && npm run build:crud-framework && npm run build:agent-registry && npm run build:marketplace && npm run build:agent-sdk",
    "publish:contracts": "npm publish --workspace=packages/contracts --access public",
    "publish:crud-framework": "npm publish --workspace=packages/crud-framework --access public",
    "publish:agent-sdk": "npm publish --workspace=packages/agent-sdk --access public",
    "publish:agent-registry": "npm publish --workspace=packages/agent-registry --access public",
    "publish:marketplace": "npm publish --workspace=packages/marketplace --access public",
    "publish:packages": "npm run build:packages && npm run publish:contracts && npm run publish:crud-framework && npm run publish:agent-registry && npm run publish:marketplace && npm run publish:agent-sdk"
  },
  "dependencies": {
    "@angular/animations": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/platform-browser-dynamic": "^18.0.0",
    "@angular/router": "^18.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@nestjs-mcp/server": "^1.0.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.3.0",
    "@nestjs/mongoose": "^10.0.6",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/websockets": "^10.4.22",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "mongoose": "^8.0.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.6.0",
    "zod": "^4.3.6",
    "zone.js": "^0.14.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.0.0",
    "@angular-devkit/core": "^18.0.0",
    "@angular-devkit/schematics": "^18.0.0",
    "@angular/cli": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@nx/angular": "^19.0.0",
    "@nx/eslint": "^19.0.0",
    "@nx/jest": "^19.0.0",
    "@nx/js": "^19.0.0",
    "@nx/nest": "^19.0.0",
    "@nx/webpack": "^19.0.0",
    "@nx/workspace": "^19.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "nx": "^19.0.0",
    "prettier": "^3.2.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
