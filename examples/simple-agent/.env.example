# Platform URL where the Wuselverse marketplace is running
PLATFORM_URL=http://localhost:3000

# Port for agent's MCP HTTP server
MCP_PORT=3001

# MCP endpoint where this agent will be reachable
MCP_ENDPOINT=http://localhost:3001/mcp

# Platform API key - must match PLATFORM_API_KEY in platform .env
# This is used to authenticate requests FROM the platform TO this agent
PLATFORM_API_KEY=platform_dev_secret_key_change_in_production

# Optional: API key for authenticated requests (obtained after registration)
API_KEY=
